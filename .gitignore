.build/
.swiftpm/
*.xcodeproj/
xcuserdata/
DerivedData/
.DS_Store
.claude/

# Tauri / Node
cue-desktop/node_modules/
cue-desktop/dist/
cue-desktop/src-tauri/gen/
cue-desktop/src-tauri/target/

# Sidecar binary is built from cue-audio-tap.swift; keep the source, not the binary
cue-desktop/src-tauri/sidecar/cue-audio-tap

# Python bytecode cache
__pycache__/
*.pyc

# Local virtualenv for the hook test suite (created by `make test-hooks`)
.venv/

# Local env / secrets
.env
.env.*

# Internal planning, prompts, audit docs, and feature specs — not for the public repo
plans/
specs/

# Stray dir created by a relative-~ path accident
/~/

# LLVM coverage instrumentation output (cargo test with -C instrument-coverage)
*.profraw

# Editor local-history snapshots (VS Code Local History extension). These hold
# copies of old file versions and must never be committed.
.history/

# Bear & Eddy maintainer-only local tooling (NEVER committed to this public OSS repo).
# These files contain absolute machine paths from the maintainer's home directory
# and internal B&E assumptions that have no place in a public repo and are useless
# to contributors. (.claude/ is already ignored above — keep it; it shields local
# settings too.)
/.mcp.json
/sentinel.config.json
/cue-desktop/sentinel.config.json
/cadence.config.json
/.sentinel/
/.codebear/
/BACKLOG.md
/CLAUDE.md
