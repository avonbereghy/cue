#!/usr/bin/env python3
"""Claude Code hook — updates session status for the menu bar app.

Called by Claude Code hooks with: claude-status-hook <idle|working|waiting|done|remove>
Receives hook JSON on stdin (contains session_id, cwd, etc.)
"""
import json
import sys
import os
import time

STATUS_DIR = os.path.expanduser("~/Library/Application Support/ClaudeStatus")
STATUS_FILE = os.path.join(STATUS_DIR, "sessions.json")
STALE_THRESHOLD = 600  # 10 minutes


def main():
    if len(sys.argv) < 2:
        return

    action = sys.argv[1]  # "idle", "working", "waiting", "done", or "remove"

    # Read hook payload from stdin
    try:
        hook_data = json.load(sys.stdin)
    except Exception:
        hook_data = {}

    session_id = hook_data.get("session_id", f"pid-{os.getppid()}")
    workspace = hook_data.get("cwd", os.getcwd())

    os.makedirs(STATUS_DIR, exist_ok=True)

    # Read existing sessions
    try:
        with open(STATUS_FILE, "r") as f:
            status = json.load(f)
    except Exception:
        status = {"sessions": {}}

    if "sessions" not in status:
        status["sessions"] = {}

    now = time.time()

    if action == "remove":
        # Session closed — remove it entirely
        status["sessions"].pop(session_id, None)
    else:
        # Update or create session
        existing = status["sessions"].get(session_id, {})
        status["sessions"][session_id] = {
            "id": session_id,
            "workspace": workspace,
            "state": action,
            "lastActivity": now,
            "startedAt": existing.get("startedAt", now),
        }

    # Prune stale sessions
    stale = [
        sid
        for sid, s in status["sessions"].items()
        if now - s.get("lastActivity", 0) > STALE_THRESHOLD
    ]
    for sid in stale:
        del status["sessions"][sid]

    # Atomic write
    tmp = STATUS_FILE + ".tmp"
    with open(tmp, "w") as f:
        json.dump(status, f, indent=2)
    os.rename(tmp, STATUS_FILE)


if __name__ == "__main__":
    main()
