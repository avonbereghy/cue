#!/usr/bin/env python3
"""Claude Code hook — updates session status for the Cue menu bar app.

Called by Claude Code hooks with: cue-hook <idle|working|waiting|done|remove>
Receives hook JSON on stdin (contains session_id, cwd, etc.)
"""
import json
import re
import sys
import os
import time
import tempfile

# --- Platform-conditional file locking (Task 5) ---
if sys.platform == "win32":
    import msvcrt

    def _lock(lock_file):
        """Acquire exclusive lock with a 2s timeout to avoid indefinite blocking.

        `LK_LOCK` blocks forever under contention, which would burn the entire
        ~5s hook budget until Claude Code kills the hook and drops the update.
        Retry the non-blocking `LK_NBLCK` every 50ms for up to 2 seconds —
        mirroring the Unix path — then give up by raising (callers guard it)."""
        # msvcrt.locking requires content covering the locked byte range
        lock_file.write(b"L")
        deadline = time.monotonic() + 2.0
        while True:
            lock_file.seek(0)
            try:
                msvcrt.locking(lock_file.fileno(), msvcrt.LK_NBLCK, 1)
                return
            except OSError:
                if time.monotonic() >= deadline:
                    raise  # Give up after 2s
                time.sleep(0.05)

    def _unlock(lock_file):
        lock_file.seek(0)
        msvcrt.locking(lock_file.fileno(), msvcrt.LK_UNLCK, 1)
else:
    import fcntl

    def _lock(lock_file):
        """Acquire exclusive lock with timeout to prevent indefinite blocking.
        Retries non-blocking lock every 50ms for up to 2 seconds."""
        deadline = time.monotonic() + 2.0
        while True:
            try:
                fcntl.flock(lock_file, fcntl.LOCK_EX | fcntl.LOCK_NB)
                return
            except (IOError, OSError):
                if time.monotonic() >= deadline:
                    raise  # Give up after 2s
                time.sleep(0.05)

    def _unlock(lock_file):
        fcntl.flock(lock_file, fcntl.LOCK_UN)


# --- WSL detection (Task 7) — filesystem inspection only, NO subprocess ---
def _is_wsl():
    """Detect WSL by checking for /proc/version containing 'microsoft'."""
    try:
        with open("/proc/version", "r") as f:
            return "microsoft" in f.read().lower()
    except (OSError, IOError):
        return False


def _get_wsl_windows_status_dir():
    """Return the Windows-side status dir path from within WSL.

    Inspects /mnt/c/Users to find the Windows username and builds the
    LOCALAPPDATA equivalent path. Returns None if detection fails.
    """
    win_users = "/mnt/c/Users"
    try:
        entries = os.listdir(win_users)
    except (OSError, IOError):
        return None

    # Filter out well-known system directories
    skip = {"Public", "Default", "Default User", "All Users", "desktop.ini"}
    candidates = [e for e in entries if e not in skip and not e.startswith(".")]

    if len(candidates) != 1:
        # Ambiguous or empty — can't auto-detect
        return None

    win_user = candidates[0]
    return os.path.join(
        win_users, win_user, "AppData", "Local", "Cue"
    )


# --- Cross-platform status directory (Task 6) ---
def get_status_dir():
    """Return OS-appropriate path for Cue data."""
    if sys.platform == "darwin":
        return os.path.expanduser("~/Library/Application Support/Cue")

    if sys.platform == "win32":
        local = os.environ.get("LOCALAPPDATA", "")
        if local:
            return os.path.join(local, "Cue")
        return os.path.expanduser("~/AppData/Local/Cue")

    # Linux (or other Unix)
    if _is_wsl():
        wsl_dir = _get_wsl_windows_status_dir()
        if wsl_dir:
            return wsl_dir

    xdg = os.environ.get("XDG_DATA_HOME", "")
    if not xdg:
        xdg = os.path.expanduser("~/.local/share")
    return os.path.join(xdg, "cue")


# --- Task 8: Use get_status_dir() instead of hardcoded path ---
STATUS_DIR = get_status_dir()
STATUS_FILE = os.path.join(STATUS_DIR, "sessions.json")
LOCK_FILE = os.path.join(STATUS_DIR, "sessions.lock")

# Required keys and their expected types for session validation (Task 4)
_SESSION_SCHEMA = {
    "id": str,
    "workspace": str,
    "state": str,
    "lastActivity": (int, float),
    "startedAt": (int, float),
    # "source" is optional — not validated (backward compat with old sessions)
}


# Allowlist for session ids used as path components downstream
# (~/.claude/projects/<encoded-ws>/<id>.jsonl). Tighter than the UUID
# grammar so it stays forward-compatible with ULID or other opaque ids
# Claude Code may emit later. Mirrors security::validate_session_id on
# the Rust side — keep the two regexes synchronised.
_SESSION_ID_RE = re.compile(r"^[A-Za-z0-9_-]{1,128}$")


def _is_valid_session_id(sid):
    """True if `sid` is safe to use as a path component and as a key in
    sessions.json. Rejects empty, oversized, separator, traversal, NUL,
    and control characters."""
    return isinstance(sid, str) and bool(_SESSION_ID_RE.match(sid))


def _validate_sessions(data):
    """Normalize sessions.json top-level structure WITHOUT dropping
    malformed individual entries.

    Earlier versions of this function discarded any entry that didn't
    match `_SESSION_SCHEMA` exactly. That ran on every hook invocation,
    so a single bad entry — from a Cue version skew, a manual edit, or
    a future field-type change — would be silently wiped the next time
    ANY OTHER session fired a hook. From the user's perspective: a
    real, live session disappeared off the dashboard with no error.

    Per-event writes always overwrite the target entry with a fully
    fresh record (the per-event code path doesn't trust the existing
    shape beyond `.get()`s), so preserving malformed entries on disk
    is safe and recoverable.
    """
    if not isinstance(data, dict):
        return {"sessions": {}}
    sessions = data.get("sessions")
    if not isinstance(sessions, dict):
        return {"sessions": {}}
    # Drop entries whose key isn't a usable session id, and entries
    # whose value isn't even a dict — those can never be looked up
    # safely by `.get()` downstream. Everything else is preserved
    # verbatim; downstream `.get()`s tolerate missing fields.
    preserved = {
        sid: entry
        for sid, entry in sessions.items()
        if _is_valid_session_id(sid) and isinstance(entry, dict)
    }
    return {"sessions": preserved}


def _subagent_jsonls_active(transcript_path, now, window_secs=30.0):
    """True if any subagent JSONL under the session's subagents/ dir
    has been modified within `window_secs`. Used by the stale-subagent
    self-heal to verify the subagents are truly gone before zeroing
    `activeSubagents`.

    Subagent JSONLs live at `<projects>/<encoded-ws>/<session_stem>/subagents/*.jsonl`
    per jsonl_parser.rs's discovery rule. We only stat — no read — so
    this is cheap to run from the hook.
    """
    if not transcript_path:
        return False
    try:
        parent_dir = os.path.dirname(transcript_path)
        session_stem = os.path.splitext(os.path.basename(transcript_path))[0]
        subagents_dir = os.path.join(parent_dir, session_stem, "subagents")
        if not os.path.isdir(subagents_dir):
            return False
        for name in os.listdir(subagents_dir):
            if not name.endswith(".jsonl"):
                continue
            try:
                mtime = os.path.getmtime(os.path.join(subagents_dir, name))
            except OSError:
                continue
            if (now - mtime) < window_secs:
                return True
    except OSError:
        pass
    return False


def _maybe_clear_stale_subagent_counter(existing, transcript_path, now):
    """Self-heal a leaked `activeSubagents` counter.

    If a session has carried `activeSubagents > 0` for more than 60 seconds AND
    no subagent JSONL has been touched in the last 30 seconds, the SubagentStop
    event was missed. Resetting `activeSubagents` in place lets this incoming
    hook event transition the state normally instead of being re-overridden
    back to "subagent" by the override at the bottom of the write path.

    Keyed on the leaked counter, NOT on `state == "subagent"`: a SubagentStart
    that fires while the card is in `waiting`/`error` increments the counter but
    deliberately preserves the user-attention state (those aren't clobbered to
    "subagent"). A missed SubagentStop there would leak a counter the old
    state-gated heal could never clear — pinning the *next* working/idle/done
    transition back to a false "subagent" until the owning process dies. The
    staleness evidence (60s age + no recently-touched subagent JSONL) still
    gates the reset, so a genuinely-running subagent is never cleared.

    Mutates `existing` in place. The Rust backend has a symmetric in-memory
    demoter (`should_demote_stale_subagent`); this is the persisted side so the
    next event sees a clean counter and the drift loop doesn't re-arm.
    """
    if existing.get("activeSubagents", 0) <= 0:
        return
    state_changed = existing.get("stateChangedAt")
    if not isinstance(state_changed, (int, float)):
        return
    if (now - state_changed) <= 60.0:
        return
    if _subagent_jsonls_active(transcript_path, now):
        return
    existing["activeSubagents"] = 0


def _quick_state_write(session_id, workspace, source, subprocess_label,
                       last_tokens, hook_start_time,
                       team_name=None, agent_name=None,
                       permission_mode=None):
    """Write 'waiting' state to sessions.json immediately so the dashboard
    flips the card the instant a prompting event fires, without waiting on
    the 1 Hz Rust JSONL re-parse.

    Used for `Notification(elicitation_dialog)` and PreToolUse(AskUserQuestion
    / ExitPlanMode). The Rust poller's `awaiting_user_prompt` verdict is the
    authoritative resolver — when the JSONL gains a matching tool_result the
    Rust side demotes `waiting` back to `idle`, so we don't pin cards forever.
    """
    if not _is_valid_session_id(session_id):
        return
    try:
        with open(LOCK_FILE, "a+b") as lock:
            lock.seek(0)
            _lock(lock)
            try:
                try:
                    with open(STATUS_FILE, "r", encoding="utf-8") as f:
                        status = json.load(f)
                except Exception:
                    status = {"sessions": {}}

                status = _validate_sessions(status)

                existing = status["sessions"].get(session_id, {})

                # Stale-write guard: if a newer hook already wrote, bail.
                existing_activity = existing.get("lastActivity", 0)
                if existing_activity > hook_start_time:
                    return

                # Mirror the main write path's stickiness: `error` outranks a
                # waiting seed. A permission/elicitation Notification arriving on
                # a session that hit a StopFailure must NOT silently downgrade
                # the red error card to yellow `waiting` and drop `errorType`.
                # The main path early-returns on an existing error; do the same
                # here so the fast-path can't bypass that guard.
                if existing.get("state") == "error":
                    return

                now = time.time()
                # If we're already on waiting, carry stateChangedAt forward
                # so the active-duration timer doesn't reset on every prompt.
                prev_state = existing.get("state", "")
                prev_changed = existing.get("stateChangedAt")
                state_changed_at = (
                    prev_changed
                    if (prev_state == "waiting" and isinstance(prev_changed, (int, float)))
                    else now
                )
                entry = {
                    "id": session_id,
                    "workspace": existing.get("workspace", workspace),
                    "state": "waiting",
                    "lastActivity": now,
                    "stateChangedAt": state_changed_at,
                    "startedAt": existing.get("startedAt", now),
                    "source": existing.get("source", source),
                    "activeSubagents": existing.get("activeSubagents", 0),
                    "pid": os.getppid(),
                }
                sub = existing.get("subprocess") or subprocess_label
                if sub:
                    entry["subprocess"] = sub
                if team_name:
                    entry["teamName"] = team_name
                if agent_name:
                    entry["agentName"] = agent_name
                if last_tokens:
                    entry["inputTokens"] = last_tokens["inputTokens"]
                    entry["outputTokens"] = last_tokens["outputTokens"]
                    if last_tokens["model"]:
                        entry["model"] = last_tokens["model"]
                elif existing.get("inputTokens"):
                    entry["inputTokens"] = existing["inputTokens"]
                    entry["outputTokens"] = existing.get("outputTokens", 0)
                    entry["model"] = existing.get("model", "")
                pm = permission_mode or existing.get("permissionMode")
                if pm:
                    entry["permissionMode"] = pm

                status["sessions"][session_id] = entry

                fd, tmp = tempfile.mkstemp(dir=STATUS_DIR, suffix=".json.tmp")
                try:
                    with os.fdopen(fd, "w", encoding="utf-8") as f:
                        json.dump(status, f, indent=2)
                        f.flush()
                        os.fsync(f.fileno())
                    if sys.platform != "win32":
                        os.chmod(tmp, 0o600)
                    os.replace(tmp, STATUS_FILE)
                except Exception:
                    try:
                        os.unlink(tmp)
                    except OSError:
                        pass
            finally:
                _unlock(lock)
    except Exception:
        pass


def _read_permission_token():
    """Read the per-launch shared secret the Cue desktop process wrote to
    STATUS_DIR/permission-token (0600) on startup.

    The token authenticates this hook to the localhost permission server so
    a co-resident malicious process can't win the loopback bind race and
    forge {"behavior":"allow"} responses to Claude Code prompts. Returns
    None if Cue isn't running, the user hasn't enabled permission
    forwarding, or the file is missing/unreadable — caller treats that as
    a soft fail and lets Claude Code fall back to its native prompt.
    """
    token_path = os.path.join(STATUS_DIR, "permission-token")
    try:
        with open(token_path, "r", encoding="utf-8") as f:
            # Token is 32 ASCII hex chars. Cap the read so a malformed/huge
            # file can't blow up the hook process.
            value = f.read(256).strip()
        return value if value else None
    except (OSError, IOError):
        return None


def _forward_permission_request(hook_data, session_id):
    """Forward a permission request to the Cue dashboard via localhost HTTP.

    The dashboard's permission server (port 3002) will block this connection
    until the user approves or denies. Returns the decision JSON or None on error.
    """
    import urllib.request
    import urllib.error

    # Refuse to forward without the per-launch shared secret. If the token
    # file is missing, Cue isn't running (or has permissions disabled), and
    # we'd otherwise be talking to whichever process happens to be bound to
    # 127.0.0.1:3002 — exactly the unauthenticated-forgery scenario the
    # token closes.
    token = _read_permission_token()
    if not token:
        return None

    payload = json.dumps({
        "session_id": session_id,
        "tool_name": hook_data.get("tool_name", "unknown"),
        "tool_input": hook_data.get("tool_input", {}),
        "hook_event_name": hook_data.get("hook_event_name", "PermissionRequest"),
    }).encode("utf-8")

    req = urllib.request.Request(
        "http://127.0.0.1:3002/permission-request",
        data=payload,
        headers={
            "Content-Type": "application/json",
            "X-Cue-Token": token,
        },
        method="POST",
    )

    try:
        with urllib.request.urlopen(req, timeout=300) as resp:
            body = resp.read().decode("utf-8")
            return json.loads(body)
    except (urllib.error.URLError, OSError, json.JSONDecodeError, TimeoutError):
        return None


def _detect_source():
    """Detect which client launched Claude Code from environment variables."""
    term = os.environ.get("TERM_PROGRAM", "")

    # VSCode and forks (Cursor, Windsurf, etc.)
    if term == "vscode" or os.environ.get("VSCODE_PID"):
        return "vscode"
    if "cursor" in term.lower():
        return "cursor"

    # Terminal emulators
    if term:
        # Map common TERM_PROGRAM values to short names
        _TERMINALS = {
            "Apple_Terminal": "terminal",
            "iTerm.app": "iterm",
            "WezTerm": "wezterm",
            "Alacritty": "alacritty",
            "tmux": "tmux",
            "screen": "screen",
            "Hyper": "hyper",
            "kitty": "kitty",
            "ghostty": "ghostty",
        }
        return _TERMINALS.get(term, term.lower())

    # No TERM_PROGRAM — could be Claude Desktop or other launcher
    return "unknown"


def _should_ignore_session(hook_data):
    """Return True for non-interactive sessions that should not appear in Cue.

    Detects `claude -p` (print mode) and other non-interactive sessions:
    1. Claude Code's own session_type field (print, pipe, headless)
    2. CUE_SKIP=1 — generic opt-out for any caller
    """
    # Claude Code includes session_type in hook data for non-interactive modes
    session_type = hook_data.get("session_type", "")
    if session_type and session_type != "interactive":
        return True
    if os.environ.get("CUE_SKIP") == "1":
        return True
    return False


# Known env vars that indicate a subprocess caller.
# Maps env var name → display label for the Cue pill.
_SUBPROCESS_ENV_MARKERS = {
    "RETENIR_SUBPROCESS": "retenir",
    "SYMPHONY_SUBPROCESS": "symphony",
    "CONDUCTOR_SUBPROCESS": "conductor",
}


def _detect_subprocess():
    """Return a subprocess label if this session is a known subprocess, else None."""
    for env_var, label in _SUBPROCESS_ENV_MARKERS.items():
        if os.environ.get(env_var):
            return label
    return None


def _detect_team(transcript_path=None):
    """Return (team_name, agent_name) if this is a team-spawned agent, else (None, None).

    Checks env vars first, then falls back to reading the JSONL transcript
    (Claude Code passes --team-name as a CLI arg, not an env var, but the
    JSONL entries carry teamName/agentName on every entry).
    """
    team = os.environ.get("CLAUDE_CODE_TEAM_NAME")
    agent = os.environ.get("CLAUDE_CODE_AGENT_NAME")
    if team:
        return team, agent
    # Fallback: check only the first few JSONL entries (session metadata).
    # Team agent sessions have teamName on every entry from the start.
    # Parent sessions do NOT — later entries may have teamName from spawned
    # agents, so we must NOT scan the whole file.
    if transcript_path:
        try:
            with open(transcript_path, "r", encoding="utf-8", errors="replace") as f:
                for i, line in enumerate(f):
                    if i >= 5:
                        break
                    line = line.strip()
                    if not line:
                        continue
                    try:
                        obj = json.loads(line)
                    except Exception:
                        continue
                    tn = obj.get("teamName")
                    an = obj.get("agentName")
                    if tn:
                        return tn, an
        except Exception:
            pass
    return None, None


# Tail-read window: start at 64 KiB (covers the last assistant line on ~95% of
# transcripts in one read) and double up to 1 MiB. A fixed small window silently
# missed the last assistant line on a large fraction of real transcripts —
# individual JSONL lines reach multiple MB and trailing non-assistant rows
# (system / file-history-snapshot / last-prompt / ai-title / tool_result) eat the
# window — causing lagging token display and transient wrong states on the
# done/idle/SubagentStop fast-paths. The Rust full-file parse is authoritative
# and self-corrects, but a wider window shrinks the wrong-state window at the
# source. The 1 MiB cap mirrors the stdin cap used elsewhere.
_TAIL_READ_INITIAL = 65536
_TAIL_READ_CAP = 1 << 20


def _scan_tail_for_assistant(transcript_path, match):
    """Scan the transcript tail backward for the newest line where `match(obj)`
    is truthy; return that parsed object or None. Reads an expanding window from
    the end of the file (doubling up to `_TAIL_READ_CAP`) so the last matching
    assistant entry isn't missed when it sits outside a small fixed window."""
    if not transcript_path:
        return None
    try:
        with open(transcript_path, "rb") as f:
            f.seek(0, 2)
            size = f.tell()
            if size == 0:
                return None
            chunk = min(size, _TAIL_READ_INITIAL)
            while True:
                f.seek(-chunk, 2)
                tail = f.read(chunk).decode("utf-8", errors="ignore")
                for line in reversed(tail.splitlines()):
                    if not line.strip():
                        continue
                    try:
                        obj = json.loads(line)
                    except Exception:
                        continue
                    if match(obj):
                        return obj
                if chunk >= size or chunk >= _TAIL_READ_CAP:
                    return None
                chunk = min(size, chunk * 2, _TAIL_READ_CAP)
    except Exception:
        pass
    return None


def _read_last_assistant(transcript_path):
    """Return the last assistant message dict from the JSONL transcript, or None."""
    return _scan_tail_for_assistant(
        transcript_path, lambda obj: obj.get("type") == "assistant"
    )


def _last_tool_was_ask_question(transcript_path):
    """Return True if the last assistant message ended with an AskUserQuestion tool call.

    Used to detect when Claude's turn ended by asking the user a question —
    in that case we want to show 'waiting' rather than 'idle'/'done'.
    """
    obj = _read_last_assistant(transcript_path)
    if not obj:
        return False
    msg = obj.get("message", {})
    content = msg.get("content", [])
    if not isinstance(content, list):
        return False
    for block in content:
        if isinstance(block, dict) and block.get("type") == "tool_use":
            if block.get("name") == "AskUserQuestion":
                return True
    return False


def _turn_has_finished(transcript_path):
    """Return True if the main session's turn has ended (stop_reason is end_turn).

    Used by SubagentStop to detect when Stop already fired while subagents
    were still running — so the last subagent finishing should go to idle,
    not working.
    """
    obj = _read_last_assistant(transcript_path)
    if not obj:
        return False
    stop_reason = (obj.get("message", {}).get("stop_reason"))
    return stop_reason == "end_turn"


def _read_last_tokens(transcript_path):
    """Read the last assistant usage entry from the JSONL transcript.
    Returns a dict with input_tokens, cache_creation, cache_read, output_tokens, model — or {}."""
    def _has_usage(obj):
        if obj.get("type") != "assistant":
            return False
        msg = obj.get("message")
        return isinstance(msg, dict) and bool(msg.get("usage"))

    obj = _scan_tail_for_assistant(transcript_path, _has_usage)
    if not obj:
        return {}
    msg = obj.get("message", {})
    usage = msg.get("usage", {})
    # Context = input + cache + output (output becomes history next turn)
    return {
        "inputTokens": (
            usage.get("input_tokens", 0)
            + usage.get("cache_creation_input_tokens", 0)
            + usage.get("cache_read_input_tokens", 0)
            + usage.get("output_tokens", 0)
        ),
        "outputTokens": usage.get("output_tokens", 0),
        "model": msg.get("model", ""),
    }


def main():
    if len(sys.argv) < 2:
        return

    action = sys.argv[1]
    valid_actions = {"idle", "working", "thinking", "waiting", "done", "remove", "error", "subagent", "subagent_stop", "compacting"}
    if action not in valid_actions:
        return  # Silently ignore unknown actions

    # Capture start time before any blocking operations (HTTP requests, etc.)
    # so we can detect if a faster hook already updated this session.
    hook_start_time = time.time()


    # Read hook payload from stdin. Cap at 1 MiB so a malformed or oversized
    # payload can't OOM the hook process (Claude Code normally sends < 10 KiB).
    try:
        raw = sys.stdin.buffer.read(1_048_576)
        hook_data = json.loads(raw) if raw else {}
    except Exception:
        hook_data = {}

    session_id = hook_data.get("session_id", f"pid-{os.getppid()}")
    # Reject session ids that aren't safe to use as a path component.
    # Untrusted-input boundary: the id is later joined into Rust's JSONL
    # file path (`<projects>/<encoded-ws>/<session_id>.jsonl`); a writer
    # supplying `..`, `/`, NUL, or absolute-path content would let Rust
    # read files outside the projects directory.
    if not _is_valid_session_id(session_id):
        return
    workspace = hook_data.get("cwd", os.getcwd())
    source = _detect_source()
    subprocess_label = _detect_subprocess()
    ignored_session = _should_ignore_session(hook_data)

    # Read latest token usage directly from the JSONL transcript. Only trust
    # the path if it resolves under the expected Claude projects directory —
    # a malformed payload could otherwise point file reads at arbitrary paths
    # (e.g., /etc/passwd, large files to stall the hook).
    transcript_path = hook_data.get("transcript_path", "")
    if transcript_path:
        try:
            resolved = os.path.realpath(transcript_path)
            claude_home = os.path.realpath(os.path.expanduser("~/.claude"))
            if not resolved.startswith(claude_home + os.sep):
                transcript_path = ""
        except Exception:
            transcript_path = ""

    team_name, agent_name = _detect_team(transcript_path)
    last_tokens = _read_last_tokens(transcript_path)
    event_name = hook_data.get("hook_event_name", "")

    # Claude Code's Notification hook fires for six subtypes. Three are
    # informational (auth_success, elicitation_complete, elicitation_response)
    # — never a state change. `idle_prompt` means "turn done, awaiting your
    # next prompt" — that's `idle`, not the amber needs-you `waiting`, so the
    # Stop→idle path already covers it; skip here.
    #
    # The two dialog subtypes DO mint `waiting`, because both are backed by a
    # JSONL signal the Rust poller can use to demote them — so they can't pin
    # the card forever:
    #   - `elicitation_dialog` accompanies an AskUserQuestion / ExitPlanMode
    #     tool_use, tracked by the Rust `awaiting_user_prompt` verdict.
    #   - `permission_prompt` means a tool that needs consent has paused the
    #     turn behind a permission dialog. It produces no prompting tool_use,
    #     but it DOES leave a real tool_use unresolved at the transcript tail;
    #     the Rust resolver holds `waiting` while that `pending_tool_use` is
    #     set and demotes the instant it clears (approved→result, denied→
    #     rejection, or the turn advances). This is the permission-prompt
    #     waiting that the dual-source refactor dropped — without it, the most
    #     common block (e.g. "Allow Bash?") silently showed as `working`.
    # Write `waiting` eagerly so the card flips at dialog-open without waiting
    # on the 1 Hz Rust re-parse; the Rust side owns the demote.
    if event_name == "Notification":
        notif_type = hook_data.get("notification_type")
        os.makedirs(STATUS_DIR, exist_ok=True)
        if notif_type in ("elicitation_dialog", "permission_prompt"):
            _quick_state_write(
                session_id, workspace, source, subprocess_label,
                last_tokens, hook_start_time,
                team_name=team_name, agent_name=agent_name,
                permission_mode=(hook_data.get("permission_mode")
                                 or hook_data.get("permissionMode")),
            )
        return

    # PermissionRequest events forward to the dashboard's permission panel
    # (when enabled) but never change session state for the same reason:
    # the resolving event isn't reliable. Forward-and-return so the
    # dashboard can still render the request, sessions.json stays untouched,
    # and the assistant remains classified as working/thinking (which is
    # what it is — gated on consent, not waiting on a user-input tool call).
    if event_name == "PermissionRequest":
        if "tool_name" in hook_data:
            decision = _forward_permission_request(hook_data, session_id)
            if decision is not None:
                json.dump(decision, sys.stdout)
                sys.stdout.flush()
        return

    # StopFailure carries an `error_type` (rate_limit / billing_error /
    # authentication_failed / server_error / model_not_found / max_output_tokens
    # / invalid_request / oauth_org_not_allowed / unknown). PostToolUseFailure
    # does not. Capture once and persist on the entry below so the UI can
    # distinguish "API rate-limited" from "Bash tool failed".
    error_type = None
    if action == "error":
        raw_err = hook_data.get("error_type")
        if isinstance(raw_err, str) and raw_err:
            error_type = raw_err

    # Permission mode comes through on PreToolUse / UserPromptSubmit / PostToolUse
    # payloads as either `permission_mode` or `permissionMode`. Normalize to a
    # canonical value Cue can render. None when the field is absent — Cue keeps
    # the previous value rather than overwriting with "unknown".
    raw_mode = hook_data.get("permission_mode") or hook_data.get("permissionMode")
    permission_mode = raw_mode if isinstance(raw_mode, str) and raw_mode else None

    os.makedirs(STATUS_DIR, exist_ok=True)

    # PreToolUse fires *before* the AskUserQuestion / ExitPlanMode dialog
    # actually opens — Claude Code may or may not also send a Notification
    # (elicitation_dialog) for it, so this is a redundant fast-path that
    # guarantees the card flips on dialog-open regardless. We promote the
    # action to `waiting` and let the main lock-held write below land it;
    # the Rust `awaiting_user_prompt` verdict demotes when the matching
    # tool_result eventually shows up in the JSONL.
    if event_name == "PreToolUse":
        tool_name = hook_data.get("tool_name")
        if isinstance(tool_name, str) and tool_name in ("AskUserQuestion", "ExitPlanMode"):
            action = "waiting"
            _quick_state_write(
                session_id, workspace, source, subprocess_label,
                last_tokens, hook_start_time,
                team_name=team_name, agent_name=agent_name,
                permission_mode=permission_mode,
            )

    # Waiting is seeded in three places, each with a deterministic Rust-side
    # demote so no card pins forever: the PreToolUse fast-path just above
    # (AskUserQuestion / ExitPlanMode), the Notification handler that early-
    # returned above (elicitation_dialog + permission_prompt), and the
    # _last_tool_was_ask_question fast-path at done/idle transitions below.
    # PermissionRequest (early-returned above) only forwards to the dashboard;
    # the actual permission-prompt waiting is minted by Notification once the
    # dialog is shown, so auto-approved requests never flip the card.

    # Hold an exclusive lock for the entire read-modify-write cycle
    # to prevent concurrent hooks from clobbering each other's updates
    with open(LOCK_FILE, "a+b") as lock:
        lock.seek(0)
        # Guard lock acquisition: on Unix `_lock` raises after a 2s flock
        # timeout (and now the Windows path raises after its own 2s deadline
        # instead of blocking). That exception would otherwise propagate
        # uncaught out of main() — silently dropping the state update AND
        # emitting a traceback to Claude Code. Degrade to a no-op instead,
        # mirroring `_quick_state_write`, which already wraps its locked write.
        try:
            _lock(lock)
        except Exception:
            return
        try:
            # Read existing sessions. If the file is present but malformed
            # (partial write, disk corruption), rename it aside instead of
            # silently resetting — that's data loss affecting every tracked
            # session on next hook.
            try:
                with open(STATUS_FILE, "r", encoding="utf-8") as f:
                    status = json.load(f)
            except FileNotFoundError:
                status = {"sessions": {}}
            except (json.JSONDecodeError, UnicodeDecodeError):
                try:
                    corrupt_path = f"{STATUS_FILE}.corrupt-{int(time.time())}"
                    os.replace(STATUS_FILE, corrupt_path)
                except OSError:
                    pass
                status = {"sessions": {}}
            except Exception:
                status = {"sessions": {}}

            # Task 4: Schema validation
            status = _validate_sessions(status)

            if ignored_session:
                # Best-effort cleanup for already-recorded subprocess ghosts.
                if status["sessions"].pop(session_id, None) is None:
                    return

                fd, tmp = tempfile.mkstemp(dir=STATUS_DIR, suffix=".json.tmp")
                try:
                    with os.fdopen(fd, "w", encoding="utf-8") as f:
                        json.dump(status, f, indent=2)
                        f.flush()
                        os.fsync(f.fileno())
                    if sys.platform != "win32":
                        os.chmod(tmp, 0o600)
                    os.replace(tmp, STATUS_FILE)
                except Exception:
                    try:
                        os.unlink(tmp)
                    except OSError:
                        pass
                    raise
                return

            now = time.time()

            if action == "remove":
                # Mark session as ended instead of deleting. This keeps the
                # card visible in Cue (frontend filters ended sessions into a
                # "revived" section). For /clear and /compact, SessionStart
                # fires immediately after SessionEnd and overwrites the entry.
                existing = status["sessions"].get(session_id, {})
                if existing:
                    existing["state"] = "ended"
                    status["sessions"][session_id] = existing
            else:
                # Update or create session
                existing = status["sessions"].get(session_id, {})

                # Detect /clear: SessionStart after SessionEnd (state="clearing")
                # means /clear was run. Also detect via transcript content for
                # sessions that weren't previously tracked by Cue.
                is_clear = False
                if action == "idle" and event_name == "SessionStart":
                    # Detect /clear or /compact: if the transcript already has
                    # content, this is a context reset, not a fresh session.
                    # Reset startedAt so the timer starts fresh.
                    has_prior = False
                    if transcript_path:
                        try:
                            has_prior = os.path.getsize(transcript_path) > 100
                        except OSError:
                            pass
                    if has_prior:
                        is_clear = True
                        # NOTE: an earlier change (F-state-coverage-004) also
                        # promoted action → "working" here for source ∈
                        # {resume, compact} on the theory that the user is
                        # mid-turn and would otherwise see a transient "idle"
                        # flash. That broke cold-start: iTerm session restore
                        # (and Claude Code's own resume path on launch) fires
                        # SessionStart with source=resume for EVERY session
                        # whose transcript exists, so every restored card
                        # pinned on "working" with no actual activity, and
                        # nothing fires a hook to demote it. The one-poll
                        # idle flash is far cheaper than the stuck-working
                        # failure mode, so the promotion is removed; the next
                        # genuine event (PreToolUse / UserPromptSubmit) will
                        # land the correct state within ~1s.

                # Self-heal a leaked subagent counter BEFORE we read it.
                # If the session has been pinned on "subagent" for >60s with
                # no subagent JSONL activity, the SubagentStop was missed —
                # reset so this event can transition normally instead of
                # being re-overridden back to "subagent" below.
                _maybe_clear_stale_subagent_counter(existing, transcript_path, now)

                # Subagent counter: increment on start, decrement on stop.
                # Per CLAUDE.md the override applies to `working`/`done`/`idle`
                # only — `waiting` and `error` need user attention and must
                # NOT be silently clobbered by subagent activity.
                active_subs = existing.get("activeSubagents", 0)
                if action in ("done", "idle"):
                    # Guard: done/idle must not overwrite states that need
                    # user attention. `waiting` already had a guard; `error`
                    # is added per the schema contract (CLAUDE.md states
                    # both are NOT overridden by counter logic).
                    existing_state = existing.get("state", "")
                    if existing_state in ("waiting", "error"):
                        return

                    if active_subs > 0:
                        # Main session went idle/done but subagents still running —
                        # override to subagent; counter resets as SubagentStops arrive
                        action = "subagent"
                    elif _last_tool_was_ask_question(transcript_path):
                        # Turn ended by asking user a question — show waiting
                        action = "waiting"
                elif action == "subagent":
                    # Don't clobber `error` or `waiting` with a subagent
                    # override on increment; preserve the user-attention
                    # state and just bump the counter under it.
                    if existing.get("state") in ("waiting", "error"):
                        active_subs += 1
                        action = existing["state"]
                    else:
                        active_subs += 1
                elif action == "subagent_stop":
                    active_subs = max(0, active_subs - 1)
                    if existing.get("state") in ("waiting", "error", "compacting", "clearing"):
                        # User-attention and transitional states must never be
                        # clobbered by subagent activity. waiting/error need
                        # the user; compacting/clearing are mid-phase — a fast
                        # subagent finish during /compact must not flash the
                        # card to "working" before PostCompact lands.
                        # Persist the decremented counter under the preserved
                        # state. (Previously this branch only preserved
                        # waiting/error, which let subagent finishes during
                        # /compact incorrectly transition through "working".)
                        action = existing["state"]
                    elif active_subs > 0:
                        # Counter still positive — show subagent.
                        action = "subagent"
                    else:
                        # If the main turn already ended (Stop fired while
                        # subagents were still running and was overridden to
                        # "subagent"), go straight to idle.
                        action = "idle" if _turn_has_finished(transcript_path) else "working"

                # While subagents are active, override "working" to "subagent"
                # so the card surfaces the parallel work. Per CLAUDE.md schema:
                #   - `thinking` is NOT overridden — the orange thinking beat
                #     must propagate so the Rust thinking→working latch can
                #     promote on the first assistant text.
                #   - `waiting` and `error` are NOT overridden — they need
                #     user attention.
                if active_subs > 0 and action == "working":
                    action = "subagent"

                # Keep the original workspace from SessionStart — prevents
                # the card title from flipping when tools cd into subdirs.
                stable_workspace = existing.get("workspace", workspace)

                # stateChangedAt: timestamp of the last actual state transition.
                # The Rust poller (1Hz) can miss brief intermediate states like
                # working→compacting→working, leaving the active-duration timer
                # accumulating since before the compact. Writing this from the
                # hook — which sees every event — gives the timer an authoritative
                # reset point. Carry forward when the action matches existing state.
                prev_state = existing.get("state", "")
                prev_changed = existing.get("stateChangedAt")
                state_changed_at = (
                    prev_changed
                    if (prev_state == action and isinstance(prev_changed, (int, float)))
                    else now
                )

                entry = {
                    "id": session_id,
                    "workspace": stable_workspace,
                    "state": action,
                    "lastActivity": now,
                    "stateChangedAt": state_changed_at,
                    "startedAt": now if is_clear else existing.get("startedAt", now),
                    "source": existing.get("source", source),
                    "activeSubagents": active_subs,
                    "pid": os.getppid(),
                }
                # Propagate subprocess label if detected (stable across events)
                sub = existing.get("subprocess") or subprocess_label
                if sub:
                    entry["subprocess"] = sub
                # Team agent metadata: only set if positively detected.
                # Don't propagate existing values — avoids stale tags on
                # parent sessions that were incorrectly tagged as children.
                if team_name:
                    entry["teamName"] = team_name
                if agent_name:
                    entry["agentName"] = agent_name
                if last_tokens:
                    entry["inputTokens"] = last_tokens["inputTokens"]
                    entry["outputTokens"] = last_tokens["outputTokens"]
                    if last_tokens["model"]:
                        entry["model"] = last_tokens["model"]
                elif existing.get("inputTokens"):
                    # Preserve last known token counts if JSONL wasn't readable
                    entry["inputTokens"] = existing["inputTokens"]
                    entry["outputTokens"] = existing.get("outputTokens", 0)
                    entry["model"] = existing.get("model", "")
                # Carry forward last known permission mode when the current
                # hook event didn't include it (e.g. SessionStart, Stop).
                pm = permission_mode or existing.get("permissionMode")
                if pm:
                    entry["permissionMode"] = pm
                # Persist errorType while the session is in "error" state.
                # Set from this event's payload (StopFailure carries error_type)
                # or carried forward from a prior error so PostToolUseFailure
                # doesn't drop the category info. Cleared on any non-error
                # transition by virtue of not being added to the new entry.
                if action == "error":
                    et = error_type or existing.get("errorType")
                    if isinstance(et, str) and et:
                        entry["errorType"] = et
                # pendingPermission is deprecated. Any legacy True value on
                # existing entries is intentionally dropped here — the new
                # entry doesn't carry it forward, so the next hook flush
                # clears the field across the dashboard.
                status["sessions"][session_id] = entry

            # Atomic write with unique temp file to avoid collisions
            fd, tmp = tempfile.mkstemp(dir=STATUS_DIR, suffix=".json.tmp")
            try:
                with os.fdopen(fd, "w", encoding="utf-8") as f:
                    json.dump(status, f, indent=2)
                    # Task 2: Flush and fsync before replace to prevent data loss
                    f.flush()
                    os.fsync(f.fileno())
                # chmod the temp file before rename so the target is never
                # briefly world-readable between replace and chmod.
                if sys.platform != "win32":
                    os.chmod(tmp, 0o600)
                # Task 1: os.replace() is atomic on all platforms
                os.replace(tmp, STATUS_FILE)
            except Exception:
                try:
                    os.unlink(tmp)
                except OSError:
                    pass
                raise
        finally:
            _unlock(lock)


if __name__ == "__main__":
    main()
