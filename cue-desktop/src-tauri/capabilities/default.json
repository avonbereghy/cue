{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Minimal capabilities for Cue",
  "windows": ["main", "signal-settings", "keyboard", "theme-picker", "tray-popover"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:window:allow-set-size",
    "core:window:allow-inner-size",
    "core:window:allow-outer-size",
    "core:window:allow-set-min-size",
    "core:window:allow-set-decorations",
    "updater:default",
    "process:default",
    "global-shortcut:default"
  ]
}
