{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui-tauri/refs/heads/main/tauri-2/schema.json",
  "productName": "Cue",
  "version": "0.1.0",
  "identifier": "com.cueapp.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Cue",
        "width": 1200,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "transparent": true
      },
      {
        "label": "tray-popover",
        "url": "index.html#/tray-popover",
        "title": "Cue Tray",
        "width": 380,
        "height": 460,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis", "msi", "deb", "appimage"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      },
      "wix": {
        "language": "en-US"
      },
      "signCommand": "signtool sign /fd SHA256 /tr http://timestamp.digicert.com /td SHA256 /sha1 %WINDOWS_CERTIFICATE_THUMBPRINT% %1"
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libayatana-appindicator3-1"],
        "section": "utils",
        "desktopTemplate": "cue.desktop"
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "14.2",
      "signingIdentity": "-",
      "hardenedRuntime": true,
      "entitlements": "macos/Cue.entitlements"
    },
    "publisher": "Cue",
    "shortDescription": "Cross-platform Claude Code session monitor",
    "category": "DeveloperTool"
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/ClaudeStage/cue/releases/latest/download/latest.json"
      ],
      "pubkey": "REPLACE_WITH_TAURI_UPDATER_PUBKEY",
      "dialog": true
    }
  }
}
