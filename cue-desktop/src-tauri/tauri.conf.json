{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui-tauri/refs/heads/main/tauri-2/schema.json",
  "productName": "Cue",
  "version": "0.5.0",
  "identifier": "com.cueapp.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Cue",
        "width": 1200,
        "height": 900,
        "maximized": true,
        "resizable": true,
        "fullscreen": false,
        "transparent": true,
        "devtools": false
      },
      {
        "label": "tray-popover",
        "url": "index.html#/tray-popover",
        "title": "Cue Tray",
        "width": 380,
        "height": 460,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": false,
        "shadow": false,
        "devtools": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: http://asset.localhost; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost; worker-src 'self' blob:; object-src 'none'; base-uri 'none'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis", "msi", "deb", "appimage"],
    "createUpdaterArtifacts": true,
    "resources": {
      "../../hooks/cue-hook": "cue-hook"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      },
      "wix": {
        "language": "en-US"
      },
      "signCommand": "signtool sign /fd SHA256 /tr http://timestamp.digicert.com /td SHA256 /sha1 %WINDOWS_CERTIFICATE_THUMBPRINT% %1"
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libayatana-appindicator3-1"],
        "section": "utils",
        "desktopTemplate": "cue.desktop"
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "14.2",
      "hardenedRuntime": true,
      "entitlements": "macos/Cue.entitlements"
    },
    "publisher": "Cue",
    "shortDescription": "Cross-platform Claude Code session monitor",
    "category": "DeveloperTool"
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/avonbereghy/cue/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVGQTFFQjYwNzVBRUJCMUEKUldRYXU2NTFZT3VoWHo1aUtQbmR2enpJS1hwNFBDOU9hL0xwZW5kV3kwczI1clZGWUFYWFpYZE0K",
      "dialog": true
    }
  }
}
